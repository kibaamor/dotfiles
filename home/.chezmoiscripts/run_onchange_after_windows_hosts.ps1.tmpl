# Self-elevate the script if required
if (-not ([Security.Principal.WindowsPrincipal] `
    [Security.Principal.WindowsIdentity]::GetCurrent() `
).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) {
    $exe = if ($PSVersionTable.PSEdition -eq 'Core') { "$PSHOME\pwsh.exe" }
            else { "$env:SystemRoot\System32\WindowsPowerShell\v1.0\powershell.exe" }

    $script = $PSCommandPath
    if (-not $script) { $script = $MyInvocation.MyCommand.Path }
    if (-not $script) { throw "No script path" }

    $args = @('-NoProfile', '-File', $script) + $args

    Start-Process -Wait -FilePath $exe -Verb RunAs -ArgumentList $args
    exit
}

$hostsPath = "$env:SystemRoot\System32\drivers\etc\hosts"
$blockedAddress = '0.0.0.0'
$blockedHosts = @(
{{- range .blocked_hosts }}
  '{{ . }}'
{{- end }}
)

$blockedSet = @{}
foreach ($hostName in $blockedHosts) {
  $blockedSet[$hostName.ToLowerInvariant()] = $true
}

$oldLines = @(Get-Content -LiteralPath $hostsPath)
$newLines = @()

foreach ($line in $oldLines) {
  if ([string]::IsNullOrWhiteSpace($line) -or $line -match '^\s*#') {
    $newLines += $line
    continue
  }

  $lineParts = @($line.Trim() -split '#', 2)
  $entry = $lineParts[0].Trim()
  $comment = if ($lineParts.Count -gt 1) { " #$($lineParts[1])" } else { '' }
  $parts = @($entry -split '\s+')
  if ($parts.Count -lt 2) {
    $newLines += $line
    continue
  }

  $keptHosts = @($parts[1..($parts.Count - 1)] | Where-Object { -not $blockedSet.ContainsKey($_.ToLowerInvariant()) })
  if ($keptHosts.Count -eq ($parts.Count - 1)) {
    $newLines += $line
  } elseif ($keptHosts.Count -gt 0) {
    $newLines += "$($parts[0]) $($keptHosts -join ' ')$comment"
  }
}

foreach ($hostName in $blockedHosts) {
  $newLines += "$blockedAddress $hostName"
}

$oldText = ($oldLines -join "`r`n").TrimEnd()
$newText = ($newLines -join "`r`n").TrimEnd()
if ($oldText -ne $newText) {
  $backupPath = "$hostsPath.bak"
  if (-not (Test-Path -LiteralPath $backupPath)) {
    Copy-Item -LiteralPath $hostsPath -Destination $backupPath
  }
  [System.IO.File]::WriteAllLines($hostsPath, $newLines, [System.Text.Encoding]::UTF8)
}
