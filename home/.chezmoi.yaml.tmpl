{{- /* https://www.chezmoi.io/reference/configuration-file/variables/ */ -}}

{{- /* https://pkg.go.dev/text/template */ -}}
{{- /* https://masterminds.github.io/sprig/ */ -}}

{{- /* checks if running interactively */ -}}
{{- $interactive := and
  stdinIsATTY
  (env "ACT" | not)
  (env "CODESPACES" | not)
  (env "DEBIAN_FRONTEND" | ne "noninteractive") -}}

{{- /* we can execute sudo command or not */ -}}
{{- $can_sudo := or $interactive (env "DOTFILES_CAN_SUDO" | ne "") -}}

{{- /* normalize architecture names used by external binary releases without calling uname on Windows */ -}}
{{- $uname_arch := "x86_64" -}}
{{- if ne .chezmoi.os "windows" -}}
{{-   $uname_arch = output "uname" "-m" | trim -}}
{{- end -}}

format: yaml

data:
  extra_bins: {{ env "DOTFILES_INSTALL_EXTRA_BINS" | ne "" }}
  arkade_bins: {{ env "DOTFILES_INSTALL_ARKADE_BINS" | ne "" }}
  use_cdn: {{ env "DOTFILES_USE_CDN" | ne "" }}
  github_url_prefix: {{ if env "DOTFILES_USE_CDN" }}https://cdn.gh-proxy.org/https://{{ else }}https://{{ end }}

  git_username: {{ env "GIT_USERNAME" | default "Kiba Amor" }}
  git_useremail: {{ env "GIT_USEREMAIL" | default "5093911+kibaamor@users.noreply.github.com" }}

  personal: {{ not (or (contains "ubisoft" .chezmoi.fqdnHostname) (contains "-WKS-" .chezmoi.fqdnHostname) (env "DOTFILES_NONPERSONAL" | ne "")) }}

  interactive: {{ $interactive }}
{{ if ne .chezmoi.os "windows" }}
  can_sudo: {{ $can_sudo }}
  sudo: {{ findExecutable "sudo" (list "/bin" "/sbin" "/usr/bin" "/usr/sbin") }}
{{ end }}

  platform: "{{ if eq .chezmoi.os "windows" }}pc{{ else if eq .chezmoi.os "darwin" }}apple{{ else }}unknown{{ end }}"
  uname_arch: "{{ $uname_arch }}"
  go_arch: "{{ if eq $uname_arch "aarch64" }}arm64{{ else }}{{ $uname_arch }}{{ end }}"
  rust_arch: "{{ if and (eq .chezmoi.os "darwin") (eq .chezmoi.arch "arm64") }}aarch64{{ else }}{{ $uname_arch }}{{ end }}"
  exe_ext: "{{ if eq .chezmoi.os "windows" }}.exe{{ end }}"
  pkg_postfix: "{{ if eq .chezmoi.os "windows" }}.zip{{ else }}.tar.gz{{ end }}"
  pkg_runtime: "{{ if eq .chezmoi.os "windows" }}-msvc{{ else if eq .chezmoi.os "linux" }}-musl{{ end }}"
