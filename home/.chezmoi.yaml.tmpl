{{- /* https://www.chezmoi.io/reference/configuration-file/variables/ */ -}}

{{- /* https://pkg.go.dev/text/template */ -}}
{{- /* https://masterminds.github.io/sprig/ */ -}}

{{- /* Detect interactive runs. */ -}}
{{- $interactive := and
  stdinIsATTY
  (env "ACT" | not)
  (env "CODESPACES" | not)
  (env "DEBIAN_FRONTEND" | ne "noninteractive") -}}

{{- /* Allow sudo when interactive or explicitly enabled. */ -}}
{{- $can_sudo := or $interactive (env "DOTFILES_CAN_SUDO" | ne "") -}}

format: yaml

data:
  git_username: {{ env "GIT_USERNAME" | default "Kiba Amor" }}
  git_useremail: {{ env "GIT_USEREMAIL" | default "5093911+kibaamor@users.noreply.github.com" }}

  blocked_hosts:
    - telemetry.business.githubcopilot.com

{{ if ne .chezmoi.os "windows" }}
  can_sudo: {{ $can_sudo }}
  sudo: {{ findExecutable "sudo" (list "/bin" "/sbin" "/usr/bin" "/usr/sbin") }}
{{ end }}
